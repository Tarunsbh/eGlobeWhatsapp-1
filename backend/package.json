    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/websockets": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/config": "^3.1.1",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.2",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/bull": "^10.1.1",
    "bull": "^4.12.2",
    "@prisma/client": "^5.9.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
