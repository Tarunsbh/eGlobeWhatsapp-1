    "uuid": "^9.0.1",
    "multer": "^1.4.5-lts.1",
    "csv-parse": "^5.5.6",
    "socket.io": "^4.7.4",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "form-data": "^4.0.0",
