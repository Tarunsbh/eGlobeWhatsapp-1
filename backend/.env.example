# ============================================================
# Hotel WhatsApp SaaS v2 — Backend Environment Variables
# Copy this to .env and fill in all values before starting
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# ─── Database (MySQL) ─────────────────────────────────────────
DATABASE_URL="mysql://wauser:wapassword@localhost:3306/hotel_wa_saas"
MYSQL_ROOT_PASSWORD=root_secret_CHANGE_ME_now
MYSQL_DATABASE=hotel_wa_saas
MYSQL_USER=wauser
MYSQL_PASSWORD=wapassword_CHANGE_ME_now

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_CHANGE_ME_now

# ─── Authentication ──────────────────────────────────────────
# Must be at least 64 random chars — never reuse across environments
JWT_SECRET=your_64_char_jwt_secret_here_change_me_before_production_please
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_64_char_refresh_secret_different_from_jwt_secret_here
REFRESH_TOKEN_EXPIRES_IN=30d

# Super Admin JWT (separate secret for isolation)
SA_JWT_EXPIRES_IN=8h

# ─── WhatsApp Cloud API ───────────────────────────────────────
WA_ACCESS_TOKEN=your_whatsapp_access_token_here
WA_PHONE_NUMBER_ID=your_phone_number_id_here
WA_BUSINESS_ACCOUNT_ID=your_business_account_id_here
WA_API_VERSION=v18.0
WA_API_BASE=https://graph.facebook.com

# ─── Webhook ─────────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=apple

# ─── Security ────────────────────────────────────────────────
# Must be exactly 32 chars — used to AES-256 encrypt stored WA tokens
TOKEN_ENCRYPTION_KEY=32characterEncryptionKeyHere1234

# ─── Email (for OTP, invoices) ───────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM="Hotel WA SaaS <noreply@yourdomain.com>"

# ─── Payment Gateways ────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Feature Flags ───────────────────────────────────────────
ENABLE_MFA=true
ENABLE_AUDIT_LOG=true
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30
PASSWORD_MIN_LENGTH=8
PASSWORD_EXPIRY_DAYS=90

# ─── ngrok (WhatsApp webhook tunnel — dev only) ───────────────
# Get free token at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Optional: claim a free static domain at dashboard.ngrok.com/cloud-edge/domains
# Without this, ngrok gives a new random URL each restart
NGROK_DOMAIN=
