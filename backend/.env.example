# ============================================================
# Hotel WhatsApp SaaS — Backend Environment Variables
# Copy this to .env and fill in all values
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# ─── Database (MySQL) ─────────────────────────────────────────
DATABASE_URL="mysql://wauser:wapassword@localhost:3306/hotel_wa_saas"
MYSQL_ROOT_PASSWORD=root_secret_change_me
MYSQL_DATABASE=hotel_wa_saas
MYSQL_USER=wauser
MYSQL_PASSWORD=wapassword_change_me

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_change_me

# ─── Authentication ──────────────────────────────────────────
JWT_SECRET=your_very_long_jwt_secret_at_least_64_chars_long_here
JWT_EXPIRES_IN=7d

# ─── WhatsApp Cloud API ───────────────────────────────────────
WA_ACCESS_TOKEN=your_whatsapp_access_token_here
WA_PHONE_NUMBER_ID=your_phone_number_id_here
WA_BUSINESS_ACCOUNT_ID=your_business_account_id_here
WA_API_VERSION=v18.0
WA_API_BASE=https://graph.facebook.com

# ─── Webhook ─────────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=apple

# ─── Security ────────────────────────────────────────────────
# Must be 32+ chars — used to AES-256 encrypt stored tokens
TOKEN_ENCRYPTION_KEY=your_32_char_encryption_key_minimum_here_!

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
